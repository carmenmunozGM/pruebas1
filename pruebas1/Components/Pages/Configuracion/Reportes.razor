@using System.Diagnostics
@using pruebas1.Servicios
@using pruebas1.Components.DTOs
@using static System.Net.WebRequestMethods
@inject AreasService AreasService
@inject HttpClient Http
@inject IJSRuntime JS
@inject EmpleadosService EmpleadosService
@inject PerfilesService PerfilesService

<div class="reportes-section">
    <div class="section-header">
        <h2>Reportes</h2>
        <p>Genera y descarga reportes de actividad</p>
    </div>

    <div class="report-type-selector">
        <button class="type-button @(reportType == "autoevaluacion" ? "active" : "")"
                @onclick='() => reportType = "autoevaluacion"'>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 11l3 3L22 4"></path>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
            </svg>
            <span>Autoevaluación</span>
        </button>

        <button class="type-button @(reportType == "clientes" ? "active" : "")"
                @onclick='() => reportType = "clientes"'>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            <span>Clientes Asignados</span>
        </button>


        <button class="type-button @(reportType == "especiales" ? "active" : "")"
                @onclick='() => reportType = "especiales"'>
            <svg width="100" height="100" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M14 2H6C4.89543 2 4 2.89543 4 4V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V8L14 2Z" stroke="#10B981" stroke-width="2" stroke-linejoin="round" />
                <path d="M14 2V8H20" stroke="#10B981" stroke-width="2" stroke-linejoin="round" />
                <path d="M8 13L9 14L12 11" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M8 17H16" stroke="#10B981" stroke-width="2" stroke-linecap="round" />
            </svg>
            <span>Reportes Especiales</span>
        </button>
    </div>

    <div class="search-section">
        @if (reportType != "especiales")
        {
            <div class="search-bar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.35-4.35"></path>
                </svg>
                <input type="text"
                       @bind="searchName"
                       @bind:event="oninput"
                       placeholder="Buscar por nombre..." />
            </div>
        }

        <select class="area-filter" @bind="selectedMonth">
            @foreach (var m in monthOptions)
            {
                <option value="@m.Value">@m.Text</option>
            }
        </select>

        @if (puedeVerFiltroArea)
        {
            <select class="area-filter" @bind="selectedArea">
                <option value="">Todas las áreas</option>
                @foreach (var area in areaList)
                {
                    <option value="@area.Area">@area.Area</option>
                }
            </select>
        }
    </div>

    <div class="reportes-table-container">
        <table class="reportes-table">
            <thead>
                <tr>
                    <th>@(reportType == "especiales" ? "Tipo de reporte" : "Usuario")</th>
                    <th>@(reportType == "especiales" ? "Acción" : "Área")</th>
                    <th class="text-right">Descargas Excel </th>
                </tr>
            </thead>
            <tbody>
                @if (reportType == "especiales")
                {
                    @foreach (var rep in new[] { "Reporte por actividad", "Reporte registro de actividades", "Reporte horas programadas" })
                    {
                        <tr>
                            <td style="vertical-align: middle;"><strong>@rep</strong></td>
                            <td style="vertical-align: middle; padding-left: 20px;">
                                @if (rep == "Reporte por actividad")
                                {
                                    <div style="display: flex; flex-direction: column; gap: 8px; width: fit-content;">
                                        <select class="area-filter" style="width: 280px; margin: 0; padding: 6px 10px; font-size: 0.9rem;"
                                                @onchange="OnServicioChanged">
                                            <option value="">-- Seleccione un Servicio --</option>
                                            @foreach (var serv in serviciosEjemplo)
                                            {
                                                <option value="@serv">@serv</option>
                                            }
                                        </select>

                                        @if (!string.IsNullOrEmpty(servicioSeleccionado))
                                        {
                                            <select class="area-filter" style="width: 280px; margin: 0; padding: 6px 10px; font-size: 0.9rem;">
                                                <option value="">-- Seleccione una Actividad --</option>
                                                @foreach (var act in actividadesFiltradas)
                                                {
                                                    <option value="@act">@act</option>
                                                }
                                            </select>
                                        }
                                    </div>
                                }
                            </td>
                            <td class="text-right" style="vertical-align: middle;">
                                <button class="download-button" >
                                    <svg class="excel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                        <polyline points="14 2 14 8 20 8"></polyline>
                                        <line x1="16" y1="13" x2="8" y2="13"></line>
                                        <line x1="16" y1="17" x2="8" y2="17"></line>
                                    </svg>
                                    <span>Descargar Excel</span>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    @foreach (var user in filteredUsers)
                    {
                        <tr>
                            <td>
                                <div class="user-cell">
                                    <div class="user-avatar">@GetInitials(user.NetName)</div>
                                    <span class="user-name">@user.Name</span>
                                </div>
                            </td>
                            <td><span class="area-badge">@user.Area</span></td>
                            <td class="text-right">
                                <button class="download-button" @onclick="() => HandleDownload(user)">
                                    <svg class="excel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                        <polyline points="14 2 14 8 20 8"></polyline>
                                        <line x1="16" y1="13" x2="8" y2="13"></line>
                                        <line x1="16" y1="17" x2="8" y2="17"></line>
                                    </svg>
                                    <span>Descargar Excel</span>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="message-toast">
            <div class="toast-content">
                <strong>@message</strong>
                <p>El archivo Excel se descargará en breve</p>
            </div>
        </div>
    }
</div>

@code {
    List<AreaDTO> areaList = new();
    List<EmpleadoDTO> empleadoList = new();
    private List<UserInfo> employees = new();

    string? selectedArea;
    private string selectedMonth = "";

    private UserInfo selectedEmployee = null;
    private string searchName = "";

    private string message = "";
    private string reportType = "autoevaluacion";

    private List<MonthOption> monthOptions = new();

    PermisosDTO? permisos;
    bool puedeVerFiltroArea = false;

    protected override async Task OnInitializedAsync()
    {
        areaList = await AreasService.GetAreas();
        GenerarMeses();
        await CargarEmpleados();

        try
        {
            permisos = await PerfilesService.GetPermisos();

            if (permisos != null)
            {
                puedeVerFiltroArea =
                    permisos.ClavePuesto == 11001 ||
                    permisos.ClavePuesto == 7202;
            }
        }
        catch
        {
            puedeVerFiltroArea = false;
        }
    }
    private string servicioSeleccionado = "";
    private List<string> serviciosEjemplo = new() { "Soporte Técnico", "Desarrollo Software", "aNALISIS INFROMARTICOS DE SEGURIDAD" };
    private List<string> actividadesFiltradas = new();

    private void OnServicioChanged(ChangeEventArgs e)
    {
        servicioSeleccionado = e.Value?.ToString() ?? "";

        // Ejemplos de actividades según el servicio
        actividadesFiltradas = servicioSeleccionado switch
        {
            "Soporte Técnico" => new() { "Revisión de PC", "Instalación de Software", "Configuración de Red" },
            "Desarrollo Software" => new() { "Corrección de Bugs", "Nueva Funcionalidad", "Code Review" },
            "Mantenimiento" => new() { "Limpieza de Servidores", "Backup Semanal", "Cambio de Hardware" },
            _ => new()
        };
    }
    private void GenerarMeses()
    {
        var cultura = new System.Globalization.CultureInfo("es-MX");
        var fechaBase = DateTime.Now;

        monthOptions = Enumerable.Range(0, 13)
            .Select(i =>
            {
                var fecha = fechaBase.AddMonths(-i);
                return new MonthOption
                {
                    Value = fecha.ToString("yyyy-MM"),
                    Text = cultura.TextInfo.ToTitleCase(
                        fecha.ToString("MMMM yyyy", cultura))
                };
            })
            .ToList();

        selectedMonth = monthOptions.First().Value;
    }

    private async Task CargarEmpleados()
    {
        var empleadosDto = await EmpleadosService.GetFiltrados();

        employees = empleadosDto
            .OrderBy(e => e.ClavePersonal)
            .Select(e => new UserInfo
            {
                Id = e.Id,
                ClavePersonal = e.ClavePersonal,
                Name = e.Nombre,
                NetName = e.NombreRed,
                Area = e.Area,
                Puesto = e.Puesto,
                Autoevaluaciones = 0,
                ProgramasTrabajo = 0,
                ClientesAsignados = 0
            }).ToList();
    }

    private int ObtenerClaveArea(string area)
    {
        return area switch
        {
            "TECNOLOGIAS DE INFORMACION" => 7,
            _ => 0
        };
    }

    private class UserInfo
    {
        public int Id { get; set; }
        public int ClavePersonal { get; set; }
        public string Name { get; set; } = string.Empty;
        public string NetName { get; set; } = string.Empty;
        public string Area { get; set; } = string.Empty;
        public string Puesto { get; set; } = string.Empty;
        public int Autoevaluaciones { get; set; }
        public int ProgramasTrabajo { get; set; }
        public int ClientesAsignados { get; set; }
    }

    private class MonthOption
    {
        public string Value { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "";
        var parts = name.Split(' ');
        return string.Join("", parts.Where(p => !string.IsNullOrEmpty(p)).Select(p => p.Substring(0, 1).ToUpper()));
    }

    private string GetReportColumnName()
    {
        return reportType switch
        {
            "autoevaluacion" => "Autoevaluaciones",
            "programa" => "Programas",
            "clientes" => "Clientes",
            _ => "Actividades"
        };
    }

    private async Task ShowMessage(string text)
    {
        message = text;
        StateHasChanged();

        await Task.Delay(2000);

        message = string.Empty;
        StateHasChanged();
    }

    private async Task HandleDownload(UserInfo user)
    {
        try
        {
            var partes = selectedMonth.Split('-');
            int anio = int.Parse(partes[0]);
            int mes = int.Parse(partes[1]);
            string areaParaReporte = string.IsNullOrEmpty(selectedArea) ? "TODAS" : selectedArea;
            string url;
            string filePrefix;

            if (reportType == "autoevaluacion")
            {
                url = $"api/Reportes/Autoevaluacion/{user.Id}/{anio}/{mes}";
                filePrefix = "autoevaluación";
            }

            else if (reportType == "clientes")
            {
                url = $"api/Reportes/ClientesAsignados/{user.Id}/{anio}/{mes}";
                filePrefix = "CLIENTES";
            }
            else
            {
                await ShowMessage("Tipo de reporte no soportado");
                return;
            }
            
            var response = await Http.GetAsync(url);

            if (response.StatusCode == System.Net.HttpStatusCode.NoContent)
            {
                await ShowMessage($"Este usuario no cuenta con reportes de {filePrefix}");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                await ShowMessage($"Este usuario no cuenta con reportes de {filePrefix}");
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();
            var fileName = $"{filePrefix}_{user.Name}_{anio}_{mes}.xlsx".Replace(" ", "_");

            await JS.InvokeVoidAsync(
                "downloadFile",
                fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                bytes
            );

            await ShowMessage($"Descargando reporte de {user.Name}");
        }
        catch (Exception ex)
        {
            await ShowMessage("Error inesperado al descargar el reporte");
            Console.WriteLine(ex);
        }
    }
    

    private string ObtenerAreaUsuario()
    {
        var usuario = employees.FirstOrDefault(e =>
            e.NetName.Equals(Environment.UserName, StringComparison.OrdinalIgnoreCase));

        return usuario?.Area ?? "";
    }
    private List<UserInfo> filteredUsers
    {
        get
        {
            return employees
                .Where(e =>
                    string.IsNullOrWhiteSpace(searchName) ||
                    e.Name.Contains(searchName, StringComparison.OrdinalIgnoreCase))
                .Where(e =>
                    string.IsNullOrEmpty(selectedArea) ||
                    e.Area.Equals(selectedArea, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }
}