@using System.Diagnostics
@using pruebas1.Servicios
@using pruebas1.Components.DTOs
@using static System.Net.WebRequestMethods
@inject AreasService AreasService
@inject HttpClient Http
@inject IJSRuntime JS
@inject EmpleadosService EmpleadosService
@inject PerfilesService PerfilesService
@inject LoginService LoginService

<div class="reportes-section">
    <div class="section-header">
        <h2>Reportes</h2>
        <p>Genera y descarga reportes de actividad</p>
    </div>

    <div class="report-type-selector">
        <button class="type-button @(reportType == "autoevaluacion" ? "active" : "")"
                @onclick='() => reportType = "autoevaluacion"'>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 11l3 3L22 4"></path>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
            </svg>
            <span>Autoevaluación</span>
        </button>

        @if (puedeVerReportesAvanzados)
        {
            <button class="type-button @(reportType == "clientes" ? "active" : "")"
            @onclick='() => reportType = "clientes"'>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            <span>Clientes Asignados</span>
        </button>
        }

        @if (puedeVerReportesAvanzados)
        {
            <button class="type-button @(reportType == "especiales" ? "active" : "")"
            @onclick='() => reportType = "especiales"'>
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14 2H6C4.89543 2 4 2.89543 4 4V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V8L14 2Z"
                    stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
                    <path d="M14 2V8H20" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
                    <path d="M8 13L9 14L12 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M8 17H16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                <span>Reportes Especiales</span>
            </button>
            }
            </div>

    <div class="search-section">
        @if (reportType != "especiales")
        {
            <div class="search-bar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.35-4.35"></path>
                </svg>
                <input type="text"
                       @bind="searchName"
                       @bind:event="oninput"
                       placeholder="Buscar por nombre..." />
            </div>
        }

        <select class="area-filter" @bind="selectedMonth">
            @foreach (var m in monthOptions)
            {
                <option value="@m.Value">@m.Text</option>
            }
        </select>

        @if (puedeVerFiltroArea)
        {
            <select class="area-filter" @bind="selectedArea">
                <option value="">Todas las áreas</option>
                @foreach (var area in areaList)
                {
                    <option value="@area.Area">@area.Area</option>
                }
            </select>
        }
    </div>

    <div class="reportes-table-container">
        <table class="reportes-table">
            <thead>
                <tr>
                    <th>@(reportType == "especiales" ? "Tipo de reporte" : "Usuario")</th>
                    <th>@(reportType == "especiales" ? "Acción" : "Área")</th>
                    <th class="text-right">Descargar en formato</th>
                </tr>
            </thead>
            <tbody>
                @if (reportType == "especiales")
                {
                    @foreach (var rep in new[] { "Reporte por actividad", "Reporte registro de actividades", "Reporte horas programadas" })
                    {
                        <tr>
                            <td style="vertical-align: middle;"><strong>@rep</strong></td>
                            <td style="vertical-align: middle; padding-left: 20px;">
                                @if (rep == "Reporte por actividad")
                                {
                                    <div style="display: flex; flex-direction: column; gap: 8px; width: fit-content;">
                                        <select class="area-filter" style="width: 280px; margin: 0; padding: 6px 10px; font-size: 0.9rem;"
                                                @onchange="OnServicioChanged">
                                            <option value="">-- Seleccione un Servicio --</option>
                                            @foreach (var serv in serviciosUsuario)
                                            {
                                                <option value="@serv.IdServicio">@serv.Servicio</option>
                                            }
                                        </select>

                                        @if (servicioSeleccionadoId != null)
                                        {
                                            <select class="area-filter"
                                                    style="width: 280px; margin: 0; padding: 6px 10px; font-size: 0.9rem;"
                                                    @bind="actividadSeleccionadaId">

                                                <option value="">-- Seleccione una Actividad --</option>

                                                @foreach (var act in actividadesFiltradas)
                                                {
                                                    <option value="@act.IdActividad">@act.Actividad</option>
                                                }
                                            </select>
                                        }
                                    </div>
                                }
                            </td>
                            <td class="text-right" style="vertical-align: middle;">
                                <div style="display:flex; gap:8px; justify-content:flex-end;">

                                    @if (rep == "Reporte por actividad")
                                    {
                                        <!-- ESTILO -->
                                        <button class="download-button"
                                                @onclick='() => HandleDownloadActividad("visual")'>
                                            <svg class="excel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                                <polyline points="14 2 14 8 20 8"></polyline>
                                                <line x1="16" y1="13" x2="8" y2="13"></line>
                                                <line x1="16" y1="17" x2="8" y2="17"></line>
                                            </svg>
                                            <span>Con estilos</span>
                                        </button>

                                        <!-- PLANO -->
                                        <button class="download-button plano-button"
                                                @onclick='() => HandleDownloadActividad("plano")'>
                                            <svg class="excel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z" />
                                                <path d="M14 2v5a1 1 0 0 0 1 1h5" />
                                            </svg>
                                            <span>Plano</span>
                                        </button>
                                    }
                                    else if (rep == "Reporte registro de actividades")
                                    {
                                        <!-- ESTILO -->
                                        <button class="download-button"
                                                @onclick='() => HandleDownloadRegistroActividades("visual")'>
                                            <svg class="excel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                                <polyline points="14 2 14 8 20 8"></polyline>
                                                <line x1="16" y1="13" x2="8" y2="13"></line>
                                                <line x1="16" y1="17" x2="8" y2="17"></line>
                                            </svg>
                                            <span>Con estilos</span>
                                        </button>

                                        <!-- PLANO -->
                                        <button class="download-button plano-button"
                                                @onclick='() => HandleDownloadRegistroActividades("plano")'>
                                            <svg class="excel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z" />
                                                <path d="M14 2v5a1 1 0 0 0 1 1h5" />
                                            </svg>
                                            <span>Plano</span>
                                        </button>
                                    }
                                    else if (rep == "Reporte horas programadas")
                                    {
                                        <!-- ESTILO -->
                                        <button class="download-button"
                                                @onclick='() => HandleDownloadHorasProgramadas("visual")'>
                                            <svg class="excel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                                <polyline points="14 2 14 8 20 8"></polyline>
                                                <line x1="16" y1="13" x2="8" y2="13"></line>
                                                <line x1="16" y1="17" x2="8" y2="17"></line>
                                            </svg>
                                            <span>Con estilos</span>
                                        </button>

                                        <!-- PLANO -->
                                        <button class="download-button plano-button"
                                                @onclick='() => HandleDownloadHorasProgramadas("plano")'>
                                            <svg class="excel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z" />
                                                <path d="M14 2v5a1 1 0 0 0 1 1h5" />
                                            </svg>
                                            <span>Plano</span>
                                        </button>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    @foreach (var user in filteredUsers)
                    {
                        <tr>
                            <td>
                                <div class="user-cell">
                                    <div class="user-avatar">@GetInitials(user.NetName)</div>
                                    <span class="user-name">@user.Name</span>
                                </div>
                            </td>
                            <td><span class="area-badge">@user.Area</span></td>
                            <td class="text-right">

                                @if (reportType == "clientes")
                                {
                                    <div style="display:flex; gap:8px; justify-content:flex-end;">

                                        <!-- FORMATO ESTILO -->
                                        <button class="download-button"
                                                @onclick='() => HandleDownload(user, "visual")'>
                                            <svg class="excel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                                <polyline points="14 2 14 8 20 8"></polyline>
                                                <line x1="16" y1="13" x2="8" y2="13"></line>
                                                <line x1="16" y1="17" x2="8" y2="17"></line>
                                            </svg>
                                            <span>Con estilos</span>
                                        </button>

                                        <!-- FORMATO PLANO -->
                                        <button class="download-button plano-button"
                                                @onclick='() => HandleDownload(user, "plano")'>
                                            <svg class="excel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z" />
                                                <path d="M14 2v5a1 1 0 0 0 1 1h5" />
                                            </svg>
                                            <span>Plano</span>
                                        </button>

                                    </div>
                                }
                                else
                                {
                                    <!-- AUTOEVALUACION -->
                                    <button class="download-button"
                                            @onclick='() => HandleDownload(user, "visual")'>
                                        <svg class="excel-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                            <polyline points="14 2 14 8 20 8"></polyline>
                                            <line x1="16" y1="13" x2="8" y2="13"></line>
                                            <line x1="16" y1="17" x2="8" y2="17"></line>
                                        </svg>
                                        <span>Autoevaluación</span>
                                    </button>
                                }

                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="message-toast">
            <div class="toast-content">
                <strong>@message</strong>
                <p>El archivo Excel se descargará en breve</p>
            </div>
        </div>
    }
</div>

@code {
    List<AreaDTO> areaList = new();
    List<EmpleadoDTO> empleadoList = new();
    private List<UserInfo> employees = new();

    string? selectedArea;
    private string selectedMonth = "";

    private UserInfo selectedEmployee = null;
    private string searchName = "";

    private string message = "";
    private string reportType = "autoevaluacion";

    private List<MonthOption> monthOptions = new();

    PermisosDTO? permisos;
    bool puedeVerFiltroArea = false;
    private int? servicioSeleccionadoId;
    private int? actividadSeleccionadaId;

    private List<ServicioConActividadesDTO> serviciosUsuario = new();
    private List<ActividadDTO> actividadesFiltradas = new();
    private int mesSeleccionado = DateTime.Now.Month;
    private int anioSeleccionado = DateTime.Now.Year;

    private Activity? actividadSeleccionada;

    bool puedeVerReportesAvanzados = false;


    private async Task CargarServiciosUsuario()
    {
        Debug.WriteLine("===== CARGAR SERVICIOS USUARIO =====");

        var area = ObtenerAreaUsuario();

        if (string.IsNullOrWhiteSpace(area))
        {
            Debug.WriteLine("No se pudo determinar el área del usuario");
            serviciosUsuario = new();
            return;
        }

        serviciosUsuario = await Http.GetFromJsonAsync<List<ServicioConActividadesDTO>>(
            $"/api/servicio-cliente/admin/servicios-actividades?area={Uri.EscapeDataString(area)}"
        ) ?? new();

        Debug.WriteLine($"Servicios recibidos: {serviciosUsuario.Count}");

        foreach (var s in serviciosUsuario)
        {
            Debug.WriteLine(
                $"Servicio -> ID: {s.IdServicio}, Nombre: {s.Servicio}, Actividades: {s.Actividades?.Count ?? 0}"
            );
        }

        Debug.WriteLine("===== FIN CARGAR SERVICIOS =====");
    }

    private void OnServicioChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var id))
            return;

        servicioSeleccionadoId = id;

        actividadesFiltradas = serviciosUsuario
            .FirstOrDefault(s => s.IdServicio == id)?
            .Actividades ?? new();

        actividadSeleccionadaId = null;
    }

    private async Task HandleDownloadActividad(string formato)
    {
        try
        {
            if (actividadSeleccionadaId == null)
            {
                await ShowMessage("Seleccione una actividad");
                return;
            }

            var partes = selectedMonth.Split('-');
            int anio = int.Parse(partes[0]);
            int mes = int.Parse(partes[1]);

            var url = $"api/Reportes/ReporteActividad/{actividadSeleccionadaId}/{anio}/{mes}?formato={formato}";

            var response = await Http.GetAsync(url);

            if (response.StatusCode == System.Net.HttpStatusCode.NoContent)
            {
                await ShowMessage("No hay registros para esta actividad");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                await ShowMessage("No se pudo generar el reporte");
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();

            var nombreActividad = actividadesFiltradas
                .FirstOrDefault(a => a.IdActividad == actividadSeleccionadaId)?.Actividad ?? "actividad";

            var fallback = $"ReporteActividad_{nombreActividad}_{mes}_{anio}.xlsx"
                .Replace(" ", "_");

            var fileName = ObtenerNombreArchivo(response, fallback);

            await JS.InvokeVoidAsync(
                "downloadFile",
                fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                bytes
            );

            await ShowMessage("Descargando reporte por actividad");
        }
        catch (Exception ex)
        {
            await ShowMessage("Error al descargar el reporte");
            Console.WriteLine(ex);
        }
    }

    private async Task HandleDownloadRegistroActividades(string formato)
    {
        try
        {
            var partes = selectedMonth.Split('-');
            int anio = int.Parse(partes[0]);
            int mes = int.Parse(partes[1]);

            string area = string.IsNullOrEmpty(selectedArea)
                ? ObtenerAreaUsuario()
                : selectedArea;

            var url = $"/api/Reportes/MinutasArea/{anio}/{mes}?area={Uri.EscapeDataString(area)}&formato={formato}";

            var response = await Http.GetAsync(url);

            if (response.StatusCode == System.Net.HttpStatusCode.NoContent)
            {
                await ShowMessage("No hay registros de actividades en este período");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                await ShowMessage("No se pudo generar el reporte");
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();

            var fallback = $"REPORTE_REGISTRO_ACTIVIDADES_{area}_{mes}_{anio}.xlsx"
                .Replace(" ", "_");

            var fileName = ObtenerNombreArchivo(response, fallback);

            await JS.InvokeVoidAsync(
                "downloadFile",
                fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                bytes
            );

            await ShowMessage("Descargando reporte de registro de actividades");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            await ShowMessage("Error al descargar el reporte");
        }
    }

    private async Task HandleDownloadHorasProgramadas(string formato)
    {
        try
        {
            var partes = selectedMonth.Split('-');
            int anio = int.Parse(partes[0]);
            int mes = int.Parse(partes[1]);

            string area = string.IsNullOrEmpty(selectedArea)
                ? ObtenerAreaUsuario()
                : selectedArea;

            var url = $"api/Reportes/HorasProgramadas/{anio}/{mes}?area={Uri.EscapeDataString(area)}&formato={formato}";

            var response = await Http.GetAsync(url);

            if (response.StatusCode == System.Net.HttpStatusCode.NoContent)
            {
                await ShowMessage("No hay horas programadas en este período");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                await ShowMessage("No se pudo generar el reporte");
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();

            var fallback = $"REPORTE_HORAS_PROGRAMADAS_{area}_{mes}_{anio}.xlsx"
                .Replace(" ", "_");

            var fileName = ObtenerNombreArchivo(response, fallback);

            await JS.InvokeVoidAsync(
                "downloadFile",
                fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                bytes
            );

            await ShowMessage("Descargando reporte de horas programadas");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            await ShowMessage("Error al descargar el reporte");
        }
    }

    private string ObtenerNombreArchivo(HttpResponseMessage response, string fallback)
    {
        var contentDisposition = response.Content.Headers.ContentDisposition;

        if (contentDisposition != null)
        {
            var fileName = contentDisposition.FileNameStar ?? contentDisposition.FileName;

            if (!string.IsNullOrEmpty(fileName))
                return fileName.Trim('"');
        }

        return fallback;
    }

    protected override async Task OnInitializedAsync()
    {
        areaList = await AreasService.GetAreas();
        GenerarMeses();

        await CargarEmpleados();
        await CargarServiciosUsuario();

        try
        {
            permisos = await PerfilesService.GetPermisos();

            if (permisos != null)
            {
                puedeVerFiltroArea =
                    permisos.ClavePuesto == 11001 ||
                    permisos.ClavePuesto == 7202 ||
                    permisos.ClavePuesto == 6201;

                puedeVerReportesAvanzados =
        permisos.ClavePuesto != 6201;
            }
        }
        catch
        {
            puedeVerFiltroArea = false;
        }
    }
    
    private void GenerarMeses()
    {
        var cultura = new System.Globalization.CultureInfo("es-MX");
        var fechaBase = DateTime.Now;

        monthOptions = Enumerable.Range(0, 13)
            .Select(i =>
            {
                var fecha = fechaBase.AddMonths(-i);
                return new MonthOption
                {
                    Value = fecha.ToString("yyyy-MM"),
                    Text = cultura.TextInfo.ToTitleCase(
                        fecha.ToString("MMMM yyyy", cultura))
                };
            })
            .ToList();

        selectedMonth = monthOptions.First().Value;
    }

    private async Task CargarEmpleados()
    {
        var empleadosDto = await EmpleadosService.GetFiltrados();

        employees = empleadosDto
            .OrderBy(e => e.ClavePersonal)
            .Select(e => new UserInfo
            {
                Id = e.Id,
                ClavePersonal = e.ClavePersonal,
                Name = e.Nombre,
                NetName = e.NombreRed,
                Area = e.Area,
                Puesto = e.Puesto,
                Autoevaluaciones = 0,
                ProgramasTrabajo = 0,
                ClientesAsignados = 0
            }).ToList();
    }

    private int ObtenerClaveArea(string area)
    {
        return area switch
        {
            "TECNOLOGIAS DE INFORMACION" => 7,
            _ => 0
        };
    }

    private class UserInfo
    {
        public int Id { get; set; }
        public int ClavePersonal { get; set; }
        public string Name { get; set; } = string.Empty;
        public string NetName { get; set; } = string.Empty;
        public string Area { get; set; } = string.Empty;
        public string Puesto { get; set; } = string.Empty;
        public int Autoevaluaciones { get; set; }
        public int ProgramasTrabajo { get; set; }
        public int ClientesAsignados { get; set; }
    }

    private class MonthOption
    {
        public string Value { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "";
        var parts = name.Split(' ');
        return string.Join("", parts.Where(p => !string.IsNullOrEmpty(p)).Select(p => p.Substring(0, 1).ToUpper()));
    }

    private string GetReportColumnName()
    {
        return reportType switch
        {
            "autoevaluacion" => "Autoevaluaciones",
            "programa" => "Programas",
            "clientes" => "Clientes",
            _ => "Actividades"
        };
    }

    private async Task ShowMessage(string text)
    {
        message = text;
        StateHasChanged();

        await Task.Delay(2000);

        message = string.Empty;
        StateHasChanged();
    }

    private async Task HandleDownload(UserInfo user, string formato)
    {
        try
        {
            var partes = selectedMonth.Split('-');
            int anio = int.Parse(partes[0]);
            int mes = int.Parse(partes[1]);
            string areaParaReporte = string.IsNullOrEmpty(selectedArea) ? "TODAS" : selectedArea;
            string url;
            string filePrefix;

            if (reportType == "autoevaluacion")
            {
                url = $"api/Reportes/Autoevaluacion/{user.Id}/{anio}/{mes}";
                filePrefix = "AE";
            }

            else if (reportType == "clientes")
            {
                url = $"api/Reportes/ClientesAsignados/{user.Id}/{anio}/{mes}?formato={formato}";
                filePrefix = formato == "plano" ? "CLIENTES_PLANO" : "CLIENTES_ESTILO";
            }
            else
            {
                await ShowMessage("Tipo de reporte no soportado");
                return;
            }
            
            var response = await Http.GetAsync(url);

            if (response.StatusCode == System.Net.HttpStatusCode.NoContent)
            {
                await ShowMessage($"Este usuario no cuenta con reportes de {filePrefix}");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                await ShowMessage($"Este usuario no cuenta con reportes de {filePrefix}");
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();
            // Cambia la línea del nombre del archivo por esta:
            var fileName = $"{filePrefix}_{mes:D2}_{anio}_{user.Name}.xlsx".Replace(" ", "_");

            await JS.InvokeVoidAsync(
                "downloadFile",
                fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                bytes
            );

            await ShowMessage($"Descargando reporte de {user.Name}");
        }
        catch (Exception ex)
        {
            await ShowMessage("Error inesperado al descargar el reporte");
            Console.WriteLine(ex);
        }
    }
    
    private string ObtenerAreaUsuario()
    {
        var usuario = LoginService.obtenerUsuarioLogueado();

        if (usuario == null)
        {
            Debug.WriteLine("❌ Usuario logueado no encontrado");
            return "";
        }

        var empleado = employees.FirstOrDefault(e =>
            e.ClavePersonal == usuario.IdEmpleado);

        if (empleado == null)
        {
            Debug.WriteLine($"❌ No se encontró empleado con clavePersonal {usuario.IdEmpleado}");
            return "";
        }

        Debug.WriteLine("===== AREA USUARIO =====");
        Debug.WriteLine($"Usuario IdEmpleado: {usuario.IdEmpleado}");
        Debug.WriteLine($"Empleado encontrado: {empleado.Name}");
        Debug.WriteLine($"Area: {empleado.Area}");
        Debug.WriteLine("========================");

        return empleado.Area?.Trim() ?? "";
    }

    private List<UserInfo> filteredUsers
    {
        get
        {
            return employees
                .Where(e =>
                    string.IsNullOrWhiteSpace(searchName) ||
                    e.Name.Contains(searchName, StringComparison.OrdinalIgnoreCase))
                .Where(e =>
                    string.IsNullOrEmpty(selectedArea) ||
                    e.Area.Equals(selectedArea, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }
